# 실행 환경 변수 예시. 실제 값은 커밋하지 말 것(.env는 .gitignore됨).

# 실행 모드: api(서버리스/프로덕션, 권위) | cli(로컬·구독)
BACKEND=api

# Messages API (api 모드 필수)
ANTHROPIC_API_KEY=sk-ant-...

# Kakao Local/Mobility (없으면 검색·동선 툴 비활성, order_route만 동작)
KAKAO_REST_API_KEY=

# 선택: Google Places(영업시간·리뷰), Supabase(영속)
GOOGLE_PLACES_API_KEY=
SUPABASE_URL=
SUPABASE_KEY=

# 서버 바인드
HOST=0.0.0.0
PORT=8080

# (선택) 종합 검색 소스 — 넣으면 Kakao와 함께 네이버·구글 결과를 합쳐 추천
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
GOOGLE_PLACES_API_KEY=
